# Example environment file for PaperPal backend
APP_NAME=paperpal
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=your_mongo_connection_string_here
MONGODB_DB=paperpal_db
MONGODB_COLLECTION_PAPERS=papers
MONGODB_COLLECTION_CHUNKS=chunks
MONGODB_COLLECTION_EMBEDDINGS=embeddings

FRONTEND_ORIGIN=https://paperpal-frontend.onrender.com
BACKEND_BASE_URL=https://paperpal-backend.onrender.com
API_PREFIX=/api/v1
API_UPLOAD_ROUTE=/papers/upload

